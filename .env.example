# Native runtime defaults
COPT_DATA_DIR=data
COPT_RUNTIME_STORE=data/runtime_store.json
RUNTIME_STORE_PATH=data/runtime_store.json
COPT_SOLVER_MODE=native

# API/frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
SERVICE_MODE=combined
OPTIMIZATION_PLATFORM_BASE_URL=http://127.0.0.1:8000
AGENT_PLATFORM_ACCESS_MODE=in_process
AGENT_ALLOW_IN_PROCESS_PLATFORM_FALLBACK=false
OPTIMIZATION_PLATFORM_TIMEOUT_SECONDS=60
OPTIMIZATION_PLATFORM_STATUS_TIMEOUT_SECONDS=3

# Docker Compose maps backend to http://127.0.0.1:18000 and stores data in ./docker-data
# The compose file overrides COPT_DATA_DIR and RUNTIME_STORE_PATH to /app/data.

{
  "name": "copt-platform-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:unit": "vitest run src/tests/unit",
    "test:unit:serial": "vitest run src/tests/unit --maxWorkers=1",
    "test:unit:diagnose": "vitest run src/tests/unit --reporter=verbose",
    "test:phase": "vitest run src/tests/unit/DashboardPage.test.tsx src/tests/unit/ScenarioLibraryPage.test.tsx src/tests/unit/ModelCreationPage.test.tsx src/tests/unit/Step2SemanticModel.test.tsx src/tests/unit/Step3MathExpansion.test.tsx src/tests/unit/Step4RuntimeParams.test.tsx src/tests/unit/Step5ReviewPublish.test.tsx src/tests/unit/ModelCenterPage.test.tsx src/tests/unit/ComponentLibraryPage.test.tsx src/tests/unit/TaskCenterPage.test.tsx src/tests/unit/ResultCenterPage.test.tsx src/tests/unit/AgentWorkbenchPage.test.tsx src/tests/unit/OfficialFrontendOnly.test.tsx",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c playwright.frontend-mock.config.ts",
    "test:e2e:mock": "playwright test -c playwright.frontend-mock.config.ts",
    "test:e2e:real": "playwright test -c playwright.real-backend.config.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@tanstack/react-query": "^5.90.0",
    "@uiw/react-codemirror": "^4.25.11",
    "antd": "^6.1.0",
    "axios": "^1.13.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  }
}
